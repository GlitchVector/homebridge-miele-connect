{
  "displayName": "Homebridge Miele Connect",
  "name": "homebridge-miele-connect",
  "type": "module",
  "version": "0.1.0",
  "description": "Homebridge plugin for Miele@home appliances (washers, dryers, dishwashers, hoods, fridges, coffee systems) via the Miele 3rd-party cloud API.",
  "author": "Remo Vetere <remo.vetere@gmail.com>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/GlitchVector/homebridge-miele-connect#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/GlitchVector/homebridge-miele-connect.git"
  },
  "bugs": {
    "url": "https://github.com/GlitchVector/homebridge-miele-connect/issues"
  },
  "keywords": [
    "homebridge-plugin",
    "miele",
    "miele-at-home",
    "miele@home"
  ],
  "main": "dist/index.js",
  "engines": {
    "node": "^18.20.4 || ^20.12.2 || ^20.18.0 || ^22.10.0 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0-beta.0"
  },
  "scripts": {
    "lint": "eslint src/**.ts --max-warnings=0",
    "lint:fix": "eslint src/**.ts --fix",
    "watch": "npm run build && npm link && nodemon",
    "build": "rimraf ./dist && tsc",
    "prepublishOnly": "npm run lint && npm run build",
    "bootstrap-oauth": "node scripts/miele-oauth-bootstrap.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/eventsource": "^1.1.15",
    "@types/node": "^22.13.4",
    "eslint": "^9.20.1",
    "homebridge": "^2.0.0-beta.0",
    "nodemon": "^3.1.9",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.0"
  },
  "dependencies": {
    "@homebridge/plugin-ui-utils": "2.0.1",
    "eventsource": "^2.0.2"
  }
}
